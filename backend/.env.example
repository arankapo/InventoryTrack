# PostgreSQL connection string.
# Local dev example:      postgresql://postgres:postgres@localhost:5432/inventrack
# Railway (after you provision a Postgres plugin) gives you this automatically
# as DATABASE_URL — just copy it from the Railway dashboard's Variables tab.
DATABASE_URL="postgresql://user:password@localhost:5432/inventrack"

# Any long random string. Generate one with: openssl rand -base64 48
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API.
# Add your Vercel frontend URL here once deployed.
CORS_ORIGIN="http://localhost:5173"
